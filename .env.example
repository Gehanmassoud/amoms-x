# NERVA Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to the repository

AZURE_SQL_SERVER=sql-amosx-prod-eus.database.windows.net
AZURE_SQL_DATABASE=db-amosx-prod
AZURE_SQL_USERNAME=amosx-admin
AZURE_SQL_PASSWORD=your-password-from-keyvault

LOGIC_APP_URL=your-logic-app-url
FOUNDRY_IQ_ENDPOINT=your-foundry-iq-endpoint
FOUNDRY_IQ_API_KEY=your-api-key

EVENT_GRID_ENDPOINT=your-event-grid-endpoint
EVENT_GRID_KEY=your-event-grid-key

AI_FOUNDRY_PROJECT=aif-amosx-prod-eus
KEY_VAULT_URL=https://kv-amosx-prod-eus.vault.azure.net/
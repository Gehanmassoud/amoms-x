# ============================================================
# NERVA Environment Variables
# Powered by AMOMS-X: Autonomous Multi-Agent Organizational
# Meta-System Extended
# ============================================================
# Copy this file to .env and populate with your own values.
# Never commit .env files, secrets, passwords, API keys,
# connection strings, tokens, or credentials to source control.
# ============================================================

# ------------------------------------------------------------
# Azure SQL
# ------------------------------------------------------------

AZURE_SQL_SERVER=your-sql-server.database.windows.net
AZURE_SQL_DATABASE=your-database-name
AZURE_SQL_USERNAME=your-sql-username
AZURE_SQL_PASSWORD=your-sql-password

# ------------------------------------------------------------
# Logic App Agent Router
# Single entry point for all agent SQL operations
# Routes via sp_AgentRouter stored procedure
# ------------------------------------------------------------

LOGIC_APP_URL=https://your-logic-app-url

# ------------------------------------------------------------
# Azure AI Foundry
# ------------------------------------------------------------

AI_FOUNDRY_PROJECT=your-foundry-project
AI_FOUNDRY_ENDPOINT=https://your-foundry-endpoint.openai.azure.com/
AI_FOUNDRY_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# Foundry IQ
# 10 enterprise policy documents
# Answer synthesis mode
# ------------------------------------------------------------

FOUNDRY_IQ_ENDPOINT=https://your-search-service.search.windows.net
FOUNDRY_IQ_INDEX=your-policy-index
FOUNDRY_IQ_API_KEY=your-api-key
FOUNDRY_IQ_KB=your-knowledge-base

# ------------------------------------------------------------
# Work IQ
# Organizational graph and human routing
# ------------------------------------------------------------

WORK_IQ_TENANT_ID=your-tenant-id
WORK_IQ_CLIENT_ID=your-client-id
WORK_IQ_CLIENT_SECRET=your-client-secret
WORK_IQ_ENDPOINT=https://your-work-iq-endpoint

# ------------------------------------------------------------
# Fabric IQ
# 12-entity ontology as semantic contract between agents
# ------------------------------------------------------------

FABRIC_IQ_WORKSPACE_ID=your-workspace-id
FABRIC_IQ_LAKEHOUSE_ID=your-lakehouse-id
FABRIC_IQ_ENDPOINT=https://api.fabric.microsoft.com
FABRIC_IQ_ONELAKE_PATH=your-onelake-path

# ------------------------------------------------------------
# Azure Event Grid
# Decentralized agent-to-agent event distribution
# ------------------------------------------------------------

EVENT_GRID_ENDPOINT=https://your-event-grid-endpoint
EVENT_GRID_KEY=your-event-grid-key

# ------------------------------------------------------------
# Azure Key Vault
# Secret management pattern for runtime configuration
# ------------------------------------------------------------

KEY_VAULT_URL=https://your-key-vault.vault.azure.net/

# ------------------------------------------------------------
# Azure AI Search
# ------------------------------------------------------------

SEARCH_ENDPOINT=https://your-search-service.search.windows.net
SEARCH_API_KEY=your-api-key

# ------------------------------------------------------------
# Microsoft Purview
# Prepared for enterprise governance, lineage, and compliance expansion
# ------------------------------------------------------------

PURVIEW_ENDPOINT=https://your-purview-endpoint
PURVIEW_COLLECTION=your-purview-collection

# ------------------------------------------------------------
# Copilot Studio Command Center
# Human-in-the-loop governance layer in Microsoft Teams
# ------------------------------------------------------------

COPILOT_STUDIO_BOT_ID=your-bot-id
COPILOT_STUDIO_TENANT_ID=your-tenant-id

# ------------------------------------------------------------
# Azure AI Foundry Agents
# ------------------------------------------------------------

CONTEXT_AGENT_ID=your-context-agent-id
REASONING_AGENT_ID=your-reasoning-agent-id
IMMUNE_AGENT_ID=your-immune-agent-id
RISK_RESPONSE_AGENT_ID=your-risk-response-agent-id
VOICE_AGENT_ID=your-voice-agent-id

# ------------------------------------------------------------
# Azure SQL Stored Procedures
# All agent SQL access goes through these procedures only
# No agent writes directly to any table
# ------------------------------------------------------------

AGENT_ROUTER_PROCEDURE=sp_AgentRouter
PROCEDURAL_MEMORY_PROCEDURE=sp_ProceduralMemory
RISK_RESPONSE_PROCEDURE=sp_RiskResponse

# ------------------------------------------------------------
# Microsoft IQ Layers
# Foundry IQ, Work IQ, and Fabric IQ provide grounding,
# organizational context, and semantic business meaning
# ------------------------------------------------------------

ENABLE_FOUNDRY_IQ=true
ENABLE_WORK_IQ=true
ENABLE_FABRIC_IQ=true

# ------------------------------------------------------------
# Voice Agent
# ------------------------------------------------------------

VOICE_AGENT_NAME=NERVA Voice
VOICE_PROVIDER=your-voice-provider

# ------------------------------------------------------------
# NERVA Resonance
# Enterprise Consequence Graph visualization
# ------------------------------------------------------------

RESONANCE_ENABLED=true
RESONANCE_NAME=NERVA Resonance

# ------------------------------------------------------------
# Governance and Learning
# ------------------------------------------------------------

ENABLE_AUDIT_LOGGING=true
ENABLE_PROCEDURAL_MEMORY=true
ENABLE_CONSEQUENCE_SIMULATION=true

# ------------------------------------------------------------
# Dynamics 365
# Prepared for enterprise customer and account enrichment
# through the Shared Enterprise Context layer
# Not connected in current hackathon build
# Azure SQL acts as live operational data source
# ------------------------------------------------------------

# DYNAMICS365_ENDPOINT=https://your-dynamics365-environment.crm.dynamics.com
# DYNAMICS365_TENANT_ID=your-tenant-id
# DYNAMICS365_CLIENT_ID=your-client-id
# DYNAMICS365_CLIENT_SECRET=your-client-secret
# DYNAMICS365_SCOPE=https://your-dynamics365-environment.crm.dynamics.com/.default

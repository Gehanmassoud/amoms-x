# NERVA Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to the repository

# Azure SQL
AZURE_SQL_SERVER=sql-amosx-prod-eus.database.windows.net
AZURE_SQL_DATABASE=db-amosx-prod
AZURE_SQL_USERNAME=amosx-admin
AZURE_SQL_PASSWORD=get-from-keyvault

# Logic App Router
LOGIC_APP_URL=https://prod-108.westus.logic.azure.com:443/workflows/...

# Azure AI Foundry
AI_FOUNDRY_PROJECT=aif-amosx-prod-eus
AI_FOUNDRY_ENDPOINT=https://aif-amosx-prod-eus.openai.azure.com/
AI_FOUNDRY_MODEL=gpt-4.1-mini

# Foundry IQ
FOUNDRY_IQ_ENDPOINT=https://srch-amosx-prod-eus.search.windows.net
FOUNDRY_IQ_INDEX=kb-amosx-policies-index
FOUNDRY_IQ_API_KEY=get-from-keyvault
FOUNDRY_IQ_KB=kb-amosx-prod

# Work IQ (Microsoft 365 Copilot)
WORK_IQ_TENANT_ID=your-m365-tenant-id
WORK_IQ_CLIENT_ID=your-m365-client-id
WORK_IQ_CLIENT_SECRET=get-from-keyvault
WORK_IQ_ENDPOINT=https://agent365.svc.cloud.microsoft

# Fabric IQ (Microsoft Fabric)
FABRIC_IQ_WORKSPACE_ID=your-fabric-workspace-id
FABRIC_IQ_LAKEHOUSE_ID=your-lakehouse-id
FABRIC_IQ_ENDPOINT=https://api.fabric.microsoft.com
FABRIC_IQ_ONELAKE_PATH=your-onelake-path

# Azure Event Grid
EVENT_GRID_ENDPOINT=your-event-grid-endpoint
EVENT_GRID_KEY=get-from-keyvault
EVENT_GRID_TOPIC=nerva-events

# Azure Key Vault
KEY_VAULT_URL=https://kv-amosx-prod-eus.vault.azure.net/

# Azure AI Search
SEARCH_ENDPOINT=https://srch-amosx-prod-eus.search.windows.net
SEARCH_API_KEY=get-from-keyvault

# Microsoft Purview DSPM
PURVIEW_ENDPOINT=your-purview-endpoint
PURVIEW_COLLECTION=nerva-governance

# Copilot Studio
COPILOT_STUDIO_BOT_ID=your-copilot-studio-bot-id
COPILOT_STUDIO_TENANT_ID=your-tenant-id
